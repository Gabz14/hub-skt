        function toggleTag(tag) {
            const index = selectedTags.indexOf(tag);
            if (index > -1) {
                selectedTags.splice(index, 1);
            } else {
                selectedTags.push(tag);
            }
            document.getElementById('aiTags').value = selectedTags.join(',');
            
            // Visual feedback
            event.target.classList.toggle('active');
        }

        function addAIKnowledge() {
            const character = document.getElementById('aiCharacterSelect').value;
            const title = document.getElementById('aiEventTitle').value.trim();
            const description = document.getElementById('aiEventDescription').value.trim();
            const tags = selectedTags.join(', ');
            
            if (!title || !description) {
                alert('Por favor, preencha o título e a descrição!');
                return;
            }
            
            const knowledge = {
                id: Date.now(),
                character: character,
                title: title,
                description: description,
                tags: tags,
                date: new Date().toLocaleDateString('pt-BR')
            };
            
            aiKnowledgeData.push(knowledge);
            localStorage.setItem('aiKnowledge', JSON.stringify(aiKnowledgeData));
            
            // Clear form
            document.getElementById('aiEventTitle').value = '';
            document.getElementById('aiEventDescription').value = '';
            selectedTags = [];
            document.querySelectorAll('.character-btn').forEach(btn => btn.classList.remove('active'));
            
            // Update display
            displayAIKnowledge('all');
            updateAIStats();
            
            alert('Conhecimento adicionado com sucesso! 🤖💜');
        }

        function displayAIKnowledge(filter) {
            const container = document.getElementById('aiKnowledgeBase');
            let filtered = aiKnowledgeData;
            
            if (filter !== 'all') {
                filtered = aiKnowledgeData.filter(k => k.character === filter);
            }
            
            // Keep the example card
            let html = `
                <div class="episode-card">
                    <div style="display: flex; justify-content: space-between; align-items: start;">
                        <div>
                            <div class="episode-title" style="font-size: 1.2rem;">📚 Exemplo de Entrada</div>
                            <div class="episode-meta">Kate Higanbana • Personalidade, Relacionamento</div>
                            <p style="color: var(--text-secondary); margin-top: 0.5rem; line-height: 1.6;">
                                Kate é extremamente leal aos amigos e à Meraki. Ela tende a agir com o coração antes da razão,
                                o que já a colocou em situações complicadas. Seu relacionamento com [nome] começou como 
                                uma amizade casual mas se desenvolveu em algo mais profundo ao longo de 2024.
                            </p>
                        </div>
                        <button class="btn" style="padding: 0.5rem 1rem; font-size: 0.85rem; background: rgba(219, 39, 119, 0.3);" onclick="alert('Esta é uma entrada de exemplo')">
                            Exemplo
                        </button>
                    </div>
                </div>
            `;
            
            filtered.reverse().forEach(k => {
                const characterName = k.character === 'kate' ? 'Kate Higanbana' : 
                                     k.character === 'duna' ? 'Duna Beaumont' :
                                     k.character === 'marcela' ? 'Marcela Garcia' :
                                     k.character === 'meraki' ? 'Gangue Meraki' : k.character;
                
                html += `
                    <div class="episode-card">
                        <div style="display: flex; justify-content: space-between; align-items: start;">
                            <div style="flex: 1;">
                                <div class="episode-title" style="font-size: 1.2rem;">${k.title}</div>
                                <div class="episode-meta">${characterName} • ${k.tags || 'Sem tags'} • ${k.date}</div>
                                <p style="color: var(--text-secondary); margin-top: 0.5rem; line-height: 1.6;">
                                    ${k.description}
                                </p>
                            </div>
                            <button class="btn" style="padding: 0.5rem 1rem; font-size: 0.85rem; background: rgba(219, 39, 119, 0.3);" onclick="deleteKnowledge(${k.id})">
                                Deletar
                            </button>
                        </div>
                    </div>
                `;
            });
            
            container.innerHTML = html;
        }

        function filterAIKnowledge(filter) {
            displayAIKnowledge(filter);
        }

        function deleteKnowledge(id) {
            if (confirm('Tem certeza que deseja deletar esta entrada?')) {
                aiKnowledgeData = aiKnowledgeData.filter(k => k.id !== id);
                localStorage.setItem('aiKnowledge', JSON.stringify(aiKnowledgeData));
                displayAIKnowledge('all');
                updateAIStats();
            }
        }

        function updateAIStats() {
            const count = aiKnowledgeData.length;
            const videoCount = videoAnalysisData.length;
            const accuracy = Math.min(100, Math.floor(count * 3 + videoCount * 10)); // Videos worth more
            
            document.getElementById('aiKnowledgeCount').textContent = count;
            document.getElementById('aiAccuracy').textContent = accuracy + '%';
            document.getElementById('videoAnalysisCount').textContent = videoCount;
            
            // Update predictions to use AI knowledge
            updatePredictionsWithAI();
        }

        function updatePredictionsWithAI() {
            // This enhances the predictions based on user-added knowledge
            // The more data, the more specific the predictions become
            
            if (aiKnowledgeData.length > 0) {
                // Group by character
                const byCharacter = {};
                aiKnowledgeData.forEach(k => {
                    if (!byCharacter[k.character]) {
                        byCharacter[k.character] = [];
                    }
                    byCharacter[k.character].push(k);
                });
                
                // Update predictions object with learned patterns
                Object.keys(byCharacter).forEach(char => {
                    if (predictions[char]) {
                        const knowledgeItems = byCharacter[char];
                        const hasPersonality = knowledgeItems.some(k => k.tags.includes('personality'));
                        const hasRelationship = knowledgeItems.some(k => k.tags.includes('relationship'));
                        const hasArc = knowledgeItems.some(k => k.tags.includes('arc'));
                        
                        if (hasPersonality || hasRelationship || hasArc) {
                            predictions[char].patterns = `Baseado em ${knowledgeItems.length} entradas de conhecimento: ` + predictions[char].patterns;
                        }
                    }
                });
            }
        }

        // Load saved content
        window.onload = function() {
            createParticles();
            generateBingo();
            updateXPDisplay();
            updateAIStats();
            displayAIKnowledge('all');
            initializeCanvas();
            updateTreeStats();
            updateTreeList();
            loadAPIKeys();
            
            const savedNotes = localStorage.getItem('rpNotes');
            const savedTheories = localStorage.getItem('rpTheories');
            
            if (savedNotes) {
                document.getElementById('personalNotes').value = savedNotes;
            }
            if (savedTheories) {
                document.getElementById('theories').value = savedTheories;
            }

            // Load custom books
            const savedBooks = JSON.parse(localStorage.getItem('customBooks') || '[]');
            const customBooksDiv = document.getElementById('customBooks');
            savedBooks.forEach(book => {
                const bookHTML = `
                    <div class="playlist-item">
                        <strong>${book.name}</strong>
                        <br><span style="font-size: 0.85rem; color: var(--text-secondary);">Categoria: ${book.category}</span>
                    </div>
                `;
                customBooksDiv.innerHTML += bookHTML;
            });
            
            // API button toggle functionality
            document.querySelectorAll('#apiClaudeVision, #apiWhisper, #apiYouTube, #apiTwitch').forEach(btn => {
                btn.addEventListener('click', function() {
                    this.classList.toggle('active');
                });
            });
        };
    </script>
