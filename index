        let treeData = JSON.parse(localStorage.getItem('familyTree') || '{"characters": [], "relationships": []}');
        let canvas, ctx;
        let selectedNode = null;
        let draggingNode = null;
        let dragOffset = {x: 0, y: 0};
        let zoomLevel = 1;
        let panOffset = {x: 0, y: 0};

        const relationshipColors = {
            romance: '#a855f7',      // Purple
            friendship: '#06b6d4',   // Cyan
            family: '#db2777',       // Pink
            rivalry: '#f97316',      // Orange
            professional: '#84cc16', // Green
            mentor: '#facc15'        // Yellow
        };

        function initializeCanvas() {
            canvas = document.getElementById('familyTreeCanvas');
            if (!canvas) return;
            
            ctx = canvas.getContext('2d');
            
            // Set canvas size
            const container = canvas.parentElement;
            canvas.width = 1200;
            canvas.height = 600;
            
            // Mouse events
            canvas.addEventListener('mousedown', handleMouseDown);
            canvas.addEventListener('mousemove', handleMouseMove);
            canvas.addEventListener('mouseup', handleMouseUp);
            canvas.addEventListener('wheel', handleWheel);
            
            // Draw initial tree
            drawTree();
        }

        function drawTree() {
            if (!ctx) return;
            
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.save();
            
            // Apply zoom and pan
            ctx.translate(panOffset.x, panOffset.y);
            ctx.scale(zoomLevel, zoomLevel);
            
            // Draw relationships (lines)
            treeData.relationships.forEach(rel => {
                const char1 = treeData.characters.find(c => c.id === rel.from);
                const char2 = treeData.characters.find(c => c.id === rel.to);
                
                if (char1 && char2) {
                    ctx.strokeStyle = relationshipColors[rel.type] || '#a5b4fc';
                    ctx.lineWidth = 2;
                    ctx.setLineDash([5, 5]);
                    
                    ctx.beginPath();
                    ctx.moveTo(char1.x, char1.y);
                    ctx.lineTo(char2.x, char2.y);
                    ctx.stroke();
                    
                    // Draw label
                    const midX = (char1.x + char2.x) / 2;
                    const midY = (char1.y + char2.y) / 2;
                    ctx.fillStyle = '#e0e7ff';
                    ctx.font = '12px "Space Mono", monospace';
                    ctx.fillText(rel.label || rel.type, midX, midY);
                }
            });
            
            ctx.setLineDash([]);
            
            // Draw characters (nodes)
            treeData.characters.forEach(char => {
                // Node circle
                ctx.fillStyle = selectedNode === char ? '#7c3aed' : '#4c1d95';
                ctx.strokeStyle = '#a855f7';
                ctx.lineWidth = 2;
                
                ctx.beginPath();
                ctx.arc(char.x, char.y, 40, 0, Math.PI * 2);
                ctx.fill();
                ctx.stroke();
                
                // Character name
                ctx.fillStyle = '#e0e7ff';
                ctx.font = 'bold 14px "Space Mono", monospace';
                ctx.textAlign = 'center';
                ctx.fillText(char.name, char.x, char.y + 5);
            });
            
            ctx.restore();
        }

        function handleMouseDown(e) {
            const rect = canvas.getBoundingClientRect();
            const x = (e.clientX - rect.left - panOffset.x) / zoomLevel;
            const y = (e.clientY - rect.top - panOffset.y) / zoomLevel;
            
            // Check if clicking on a node
            const clicked = treeData.characters.find(char => {
                const dist = Math.sqrt((char.x - x) ** 2 + (char.y - y) ** 2);
                return dist < 40;
            });
            
            if (clicked) {
                draggingNode = clicked;
                dragOffset = {x: x - clicked.x, y: y - clicked.y};
                selectedNode = clicked;
                canvas.style.cursor = 'grabbing';
            }
        }

        function handleMouseMove(e) {
            const rect = canvas.getBoundingClientRect();
            const x = (e.clientX - rect.left - panOffset.x) / zoomLevel;
            const y = (e.clientY - rect.top - panOffset.y) / zoomLevel;
            
            if (draggingNode) {
                draggingNode.x = x - dragOffset.x;
                draggingNode.y = y - dragOffset.y;
                drawTree();
                saveTree();
                return;
            }
            
            // Tooltip
            const hovered = treeData.characters.find(char => {
                const dist = Math.sqrt((char.x - x) ** 2 + (char.y - y) ** 2);
                return dist < 40;
            });
            
            const tooltip = document.getElementById('canvasTooltip');
            if (hovered) {
                canvas.style.cursor = 'pointer';
                const relations = treeData.relationships.filter(r => r.from === hovered.id || r.to === hovered.id);
                tooltip.innerHTML = `<strong>${hovered.name}</strong><br>${relations.length} relacionamentos`;
                tooltip.style.left = e.clientX - rect.left + 10 + 'px';
                tooltip.style.top = e.clientY - rect.top + 10 + 'px';
                tooltip.style.display = 'block';
            } else {
                canvas.style.cursor = 'grab';
                tooltip.style.display = 'none';
            }
        }

        function handleMouseUp() {
            draggingNode = null;
            canvas.style.cursor = 'grab';
        }

        function handleWheel(e) {
            e.preventDefault();
            const delta = e.deltaY > 0 ? 0.9 : 1.1;
            zoomLevel *= delta;
            zoomLevel = Math.max(0.5, Math.min(3, zoomLevel));
            drawTree();
        }

        function centerTree() {
            if (treeData.characters.length === 0) return;
            
            const avgX = treeData.characters.reduce((sum, c) => sum + c.x, 0) / treeData.characters.length;
            const avgY = treeData.characters.reduce((sum, c) => sum + c.y, 0) / treeData.characters.length;
            
            panOffset.x = canvas.width / 2 - avgX * zoomLevel;
            panOffset.y = canvas.height / 2 - avgY * zoomLevel;
            
            drawTree();
        }

        function autoLayout() {
            if (treeData.characters.length === 0) return;
            
            // Simple circular layout
            const centerX = canvas.width / 2;
            const centerY = canvas.height / 2;
            const radius = Math.min(canvas.width, canvas.height) / 3;
            
            treeData.characters.forEach((char, i) => {
                const angle = (i / treeData.characters.length) * Math.PI * 2;
                char.x = centerX + Math.cos(angle) * radius;
                char.y = centerY + Math.sin(angle) * radius;
            });
            
            panOffset = {x: 0, y: 0};
            zoomLevel = 1;
            drawTree();
            saveTree();
        }

        function zoomIn() {
            zoomLevel *= 1.2;
            zoomLevel = Math.min(3, zoomLevel);
            drawTree();
        }

        function zoomOut() {
            zoomLevel *= 0.8;
            zoomLevel = Math.max(0.5, zoomLevel);
            drawTree();
        }

